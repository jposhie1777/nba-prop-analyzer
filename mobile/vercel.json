{
  "framework": null,
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/_expo/(.*)",
      "dest": "/_expo/$1",
      "headers": {
        "Content-Type": "application/javascript"
      }
    },
    {
      "src": "/(.*)\\.(js|css|map|json|png|jpg|svg|ico|woff2?)",
      "dest": "/$1"
    },
    {
      "src": "^/api/mlb/matchups/([0-9]+)$",
      "dest": "/api/mlb/matchups/detail?game_pk=$1"
    },
    {
      "src": "^/api/mlb/matchups/([0-9]+)/pitching-props$",
      "dest": "/api/mlb/matchups/pitching-props?game_pk=$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://mobile-api-763243624328.us-central1.run.app/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
